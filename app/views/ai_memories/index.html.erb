<% content_for :title, t(".title") %>

<div class="w-full max-w-2xl">
  <%= page_header title: t(".title") do %>
    <div class="flex gap-2">
      <% if current_user.ai_configured? && !@generating %>
        <%= button t(".generate"),
        type: "submit",
        style: "primary",
        method: :post,
        route: generate_ai_memories_path %>
      <% end %>
      <%= button t(".back"),
      type: "link",
      style: "outlined",
      route: ai_trainer_activities_path %>
    </div>
  <% end %>

  <p class="text-slate-400 text-sm mb-6"><%= t(".description") %></p>

  <% if @generating %>
    <%= turbo_stream_from current_user, :ai_memory_generation %>
    <div
      id="ai_memory_generation_status"
      class="bg-slate-800 rounded-lg p-8 text-center mb-6"
    >
      <div class="flex flex-col items-center gap-3">
        <svg
          class="animate-spin h-8 w-8 text-blue-500"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
        >
          <circle
            class="opacity-25"
            cx="12"
            cy="12"
            r="10"
            stroke="currentColor"
            stroke-width="4"
          ></circle>
          <path
            class="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"
          ></path>
        </svg>
        <p class="text-slate-300 font-medium"><%= t(".generating") %></p>
        <p class="text-slate-500 text-sm"><%= t(".generating_hint") %></p>
      </div>
    </div>
  <% end %>

  <% if @memories.any? %>
    <div class="space-y-6">
      <% AiMemory.categories.keys.each do |category| %>
        <% next unless @memories[category]&.any? %>

        <div>
          <%= section_header title: t(".categories.#{category}"),
          icon: memory_category_icon(category) %>

          <div class="space-y-2 mt-2">
            <% @memories[category].each do |memory| %>
              <div class="bg-slate-800 rounded-lg p-3 border border-slate-700">
                <div class="flex items-start justify-between gap-3">
                  <p class="text-slate-300 text-sm flex-1">
                    <%= memory.content %>
                  </p>
                  <%= button t("shared.buttons.delete"),
                  style: "link_danger",
                  method: :delete,
                  route: ai_memory_path(memory),
                  data: {
                    turbo_confirm: t("shared.confirmations.are_you_sure"),
                  } %>
                </div>
                <div class="flex items-center gap-3 mt-2 pt-2 border-t border-slate-700/50">
                  <div
                    class="flex items-center gap-1.5"
                    title="<%= t(".importance") %>: <%= memory.importance %>/10"
                  >
                    <%= importance_bars(memory.importance) %>
                    <span
                      class="text-xs"
                      style="color: <%= importance_level(memory.importance)[:color] %>"
                    >
                      <%= t(".importance_levels.#{importance_level(memory.importance)[:label_key]}") %>
                    </span>
                  </div>
                  <span class="text-slate-600">·</span>
                  <span class="text-xs text-slate-500">
                    <%= l(memory.created_at, format: :short) %>
                  </span>
                  <% if memory.embedding.present? %>
                    <span class="text-slate-600">·</span>
                    <span class="text-xs text-emerald-500/70" title="<%= t(".has_embedding") %>">
                      <%= t(".embedded") %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% elsif !@generating %>
    <%= empty_state icon: "sparkles", message: t(".empty") do %>
      <% if current_user.ai_configured? %>
        <%= button t(".generate"),
        type: "submit",
        style: "primary",
        method: :post,
        route: generate_ai_memories_path %>
      <% end %>
    <% end %>
  <% end %>
</div>
