<% content_for :title, @exercise.name %>

<div class="w-full max-w-3xl">
  <div class="flex items-center justify-between mb-6">
    <%= link_to exercises_path, class: "text-slate-400 hover:text-slate-300 flex items-center gap-2" do %>
      <%= icon "back", size: "w-5 h-5" %>
      <%= t(".back_to_exercises") %>
    <% end %>
    <div class="flex items-center gap-4">
      <%= link_to t("shared.buttons.edit"),
      edit_exercise_path(@exercise),
      class: "text-blue-400 hover:text-blue-300" %>
      <%= button t("shared.buttons.delete"),
      route: exercise_path(@exercise),
      method: :delete,
      style: "link_danger",
      data: {
        turbo_confirm: t("shared.confirmations.are_you_sure"),
      } %>
    </div>
  </div>

  <div class="bg-slate-800 rounded-lg p-6 mb-6">
    <div class="flex items-center gap-3 mb-4">
      <% if @exercise.muscle.present? %>
        <span class="text-slate-400"><%= muscle_icon(@exercise.muscle, size: "w-8 h-8") %></span>
      <% end %>
      <h1 class="font-bold text-3xl"><%= @exercise.name %></h1>
    </div>

    <% if @exercise.muscle.present? %>
      <p class="text-slate-400 mb-4"><%= @exercise.muscle.human_name %></p>
    <% end %>

    <div class="flex gap-2">
      <% if @exercise.with_weights %>
        <span
          class="
            inline-flex items-center gap-1 px-3 py-1 bg-blue-600/20 text-blue-400
            rounded-full text-sm
          "
        >
          <%= icon "dumbbell" %>
          <%= t(".weights") %>
        </span>
      <% end %>
      <% if @exercise.with_band %>
        <span
          class="
            inline-flex items-center gap-1 px-3 py-1 bg-purple-600/20 text-purple-400
            rounded-full text-sm
          "
        >
          <%= icon "band" %>
          <%= t(".band") %>
        </span>
      <% end %>
    </div>
  </div>

  <% if @workout_sets.any? %>
    <% max_weight =
      @workout_sets.flat_map(&:workout_reps).compact.map(&:weight).compact.max %>
    <% total_sets = @workout_sets.size %>

    <div class="grid grid-cols-2 gap-4 mb-6">
      <div class="bg-slate-800 rounded-lg p-4">
        <div class="text-slate-400 text-sm mb-1"><%= t(".total_sets") %></div>
        <div class="text-2xl font-bold"><%= total_sets %></div>
      </div>
      <% if max_weight && max_weight > 0 %>
        <div class="bg-slate-800 rounded-lg p-4">
          <div class="text-slate-400 text-sm mb-1"><%= t(".max_weight") %></div>
          <div class="text-2xl font-bold"><%= max_weight %>KG</div>
        </div>
      <% else %>
        <div class="bg-slate-800 rounded-lg p-4">
          <div class="text-slate-400 text-sm mb-1"><%= t(".last_performed") %></div>
          <div class="text-2xl font-bold"><%= @workout_sets.first.created_at.strftime("%b %d") %></div>
        </div>
      <% end %>
    </div>

    <% if @chart_data[:labels]&.size.to_i > 1 %>
      <h2 class="text-lg font-semibold mb-4"><%= t(".progression") %></h2>
      <div class="grid gap-4 mb-6">
        <% if @exercise.with_weights %>
          <div class="bg-slate-800 rounded-lg p-4">
            <h3 class="text-sm font-medium text-slate-400 mb-2"><%= t(".max_weight_chart") %></h3>
            <div class="h-48">
              <canvas
                data-controller="chart"
                data-chart-type-value="line"
                data-chart-labels-value="<%= @chart_data[:labels].to_json %>"
                data-chart-datasets-value="<%= [{
                  label: t(".weight_kg"),
                  data: @chart_data[:max_weight],
                  borderColor: 'rgb(59, 130, 246)',
                  backgroundColor: 'rgba(59, 130, 246, 0.1)',
                  fill: true,
                  tension: 0.3,
                  pointRadius: 3,
                  pointBackgroundColor: 'rgb(59, 130, 246)'
                }].to_json %>"
                data-chart-options-value="<%= {
                  scales: {
                    y: {
                      beginAtZero: false,
                      title: { display: true, text: t(".weight_kg"), color: '#94a3b8' },
                      ticks: { color: '#94a3b8' },
                      grid: { color: '#334155' }
                    },
                    x: {
                      ticks: { color: '#94a3b8', maxRotation: 45 },
                      grid: { color: '#334155' }
                    }
                  },
                  plugins: {
                    legend: { display: false }
                  }
                }.to_json %>"
              ></canvas>
            </div>
          </div>

          <div class="bg-slate-800 rounded-lg p-4">
            <h3 class="text-sm font-medium text-slate-400 mb-2"><%= t(".volume_chart") %></h3>
            <div class="h-48">
              <canvas
                data-controller="chart"
                data-chart-type-value="bar"
                data-chart-labels-value="<%= @chart_data[:labels].to_json %>"
                data-chart-datasets-value="<%= [{
                  label: t(".volume_kg"),
                  data: @chart_data[:volume],
                  backgroundColor: 'rgba(34, 197, 94, 0.7)',
                  borderColor: 'rgb(34, 197, 94)',
                  borderWidth: 1,
                  borderRadius: 4
                }].to_json %>"
                data-chart-options-value="<%= {
                  scales: {
                    y: {
                      beginAtZero: true,
                      title: { display: true, text: t(".volume_kg"), color: '#94a3b8' },
                      ticks: { color: '#94a3b8' },
                      grid: { color: '#334155' }
                    },
                    x: {
                      ticks: { color: '#94a3b8', maxRotation: 45 },
                      grid: { color: '#334155' }
                    }
                  },
                  plugins: {
                    legend: { display: false }
                  }
                }.to_json %>"
              ></canvas>
            </div>
          </div>
        <% end %>

        <div class="bg-slate-800 rounded-lg p-4">
          <h3 class="text-sm font-medium text-slate-400 mb-2"><%= t(".best_reps_chart") %></h3>
          <div class="h-48">
            <canvas
              data-controller="chart"
              data-chart-type-value="line"
              data-chart-labels-value="<%= @chart_data[:labels].to_json %>"
              data-chart-datasets-value="<%= [{
                label: t(".reps"),
                data: @chart_data[:best_reps],
                borderColor: 'rgb(168, 85, 247)',
                backgroundColor: 'rgba(168, 85, 247, 0.1)',
                fill: true,
                tension: 0.3,
                pointRadius: 3,
                pointBackgroundColor: 'rgb(168, 85, 247)'
              }].to_json %>"
              data-chart-options-value="<%= {
                scales: {
                  y: {
                    beginAtZero: true,
                    title: { display: true, text: t(".reps"), color: '#94a3b8' },
                    ticks: { color: '#94a3b8', stepSize: 1 },
                    grid: { color: '#334155' }
                  },
                  x: {
                    ticks: { color: '#94a3b8', maxRotation: 45 },
                    grid: { color: '#334155' }
                  }
                },
                plugins: {
                  legend: { display: false }
                }
              }.to_json %>"
            ></canvas>
          </div>
        </div>
      </div>
    <% end %>

    <h2 class="text-lg font-semibold mb-4"><%= t(".previous_results") %></h2>

    <div class="space-y-3">
      <% @workout_sets.group_by { |ws| ws.created_at.to_date }.each do |date, sets| %>
        <div class="bg-slate-800 rounded-lg overflow-hidden">
          <div class="bg-slate-700/50 px-4 py-2 border-b border-slate-700">
            <div class="flex items-center justify-between">
              <span class="font-medium"><%= date.strftime("%A, %B %d") %></span>
              <span class="text-slate-400 text-sm"><%= pluralize(sets.size, "set") %></span>
            </div>
          </div>

          <div class="divide-y divide-slate-700">
            <% sets.each do |workout_set| %>
              <div class="px-4 py-3">
                <div class="flex items-center justify-between mb-2">
                  <div class="flex items-center gap-2 text-sm text-slate-400">
                    <span><%= workout_set.created_at.strftime("%H:%M") %></span>
                    <span class="text-slate-600">|</span>
                    <span>
                      <%= Time.at(workout_set.ended_at - workout_set.started_at).utc.strftime("%M:%S") %>
                      <%= t(".duration") %>
                    </span>
                    <% if workout_set.workout&.workout_routine_day %>
                      <span class="text-slate-600">|</span>
                      <span class="text-blue-400"><%= workout_set.workout.workout_routine_day.name %></span>
                    <% end %>
                  </div>
                </div>

                <div class="flex flex-wrap gap-2">
                  <% workout_set.workout_reps.each do |rep| %>
                    <div
                      class="
                        inline-flex items-center gap-1 px-2 py-1 bg-slate-700 rounded text-sm
                      "
                    >
                      <span class="font-medium"><%= rep.reps %></span>
                      <% if rep.weight %>
                        <span class="text-slate-400">x</span>
                        <span class="text-green-400"><%= rep.weight %>kg</span>
                      <% end %>
                      <% if rep.band %>
                        <span class="text-slate-400">x</span>
                        <span class="text-purple-400"><%= rep.band %></span>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= empty_state emoji: "📊",
    title: t(".no_history_title"),
    message: t(".no_history_description") %>
  <% end %>
</div>
