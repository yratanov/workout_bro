<div class="bg-slate-700 rounded relative" data-controller="accordion">
  <div
    class="
      flex bg-slate-800 items-center rounded-t justify-between px-4 py-3 gap-2
    "
  >
    <button
      data-action="click->accordion#toggle"
      data-accordion-target="trigger"
      class="w-full cursor-pointer transition flex items-center gap-3"
      aria-expanded="<%= workout_set.running? || workout_set.workout.ended? ? "true" : "false" %>"
    >
      <div data-accordion-target="icon" class="text-slate-400">
        <%= icon "chevron_down" %>
      </div>
      <% if workout_set.exercise.muscle.present? %>
        <span class="text-slate-400"><%= muscle_icon(workout_set.exercise.muscle, size: "w-5 h-5") %></span>
      <% end %>
      <span class="font-semibold text-lg"><%= workout_set.exercise.name %></span>
      <%= badge do %>
        <div class="flex gap-1 items-center">
          <%= icon "stopwatch" %>
          <%= render(
            TimerComponent.new(
              started_at: workout_set.started_at,
              ended_at: workout_set.ended_at,
              paused_at: workout_set.paused_at,
              total_paused_seconds: workout_set.total_paused_seconds,
            ),
          ) %>
        </div>
      <% end %>
    </button>
    <div class="flex items-center gap-1">
      <%= link_to notes_modal_workout_set_path(workout_set),
        class: "p-1 text-slate-400 hover:text-blue-400 transition-colors",
        data: { turbo_frame: "notes_modal" },
        title: t("shared.buttons.add_note") do %>
        <%= icon "note", size: "w-4 h-4" %>
      <% end %>
      <%= button route: workout_set_path(workout_set),
      method: :delete,
      type: 'button',
      style: "link_hover_danger",
      data: {
        turbo_confirm: t("shared.confirmations.are_you_sure"),
      } do %>
        <%= icon "xmark" %>
      <% end %>
    </div>
  </div>

  <div
    class="overflow-hidden transition-all duration-200 ease-in-out"
    data-accordion-target="content"
  >
    <div class="py-3 px-4">
      <%= turbo_frame_tag workout_set, "reps" do %>
        <%= render partial: "workout_reps/list_with_form",
        locals: {
          workout_set:,
          workout_rep: workout_set.workout_reps.new(workout_set.default_rep_values),
        } %>
      <% end %>
      <% if (rde = routine_day_exercise_for_set(workout_set)) %>
        <% recommendation_parts = [] %>
        <% if rde.sets.present?
          recommendation_parts << t(
            "workout_sets.workout_set.sets_target",
            count: rde.sets,
          )
        end %>
        <% if rde.reps.present?
          recommendation_parts << t(
            "workout_sets.workout_set.reps_target",
            count: rde.reps,
          )
        end %>
        <% if rde.min_rest.present? && rde.max_rest.present? && rde.min_rest != rde.max_rest %>
          <% recommendation_parts << t(
            "workout_sets.workout_set.rest_range",
            min: rde.min_rest,
            max: rde.max_rest,
          ) %>
        <% elsif rde.max_rest.present? %>
          <% recommendation_parts << t(
            "workout_sets.workout_set.rest_target",
            seconds: rde.max_rest,
          ) %>
        <% end %>
        <% if recommendation_parts.any? %>
          <div class="text-blue-400 text-sm mt-2"><%= recommendation_parts.join(" · ") %></div>
        <% end %>
        <% if rde.comment.present? %>
          <div class="text-blue-400/70 text-sm mt-1 italic"><%= rde.comment %></div>
        <% end %>
      <% end %>
      <%= render partial: "workout_sets/notes",
      locals: {
        workout_set: workout_set,
        edit_path: notes_modal_workout_set_path(workout_set),
      } %>
    </div>

    <% unless workout_set.ended? %>
      <div class="px-4 py-3 flex rounded-b justify-center bg-slate-800">
        <%= button t("workout_sets.workout_set.complete_set"),
        type: "button",
        style: "success",
        method: :post,
        route: stop_workout_set_path(workout_set),
        data: {
          turbo_method: :post,
        } %>
      </div>
    <% end %>
  </div>
</div>
