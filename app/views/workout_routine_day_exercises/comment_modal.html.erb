<%= turbo_frame_tag "comment_modal" do %>
  <div
    data-controller="modal"
    data-modal-auto-open-value="true"
    data-modal-turbo-frame-value="comment_modal"
  >
    <%= modal title: t(".title", exercise: @workout_routine_day_exercise.display_name), size: "md" do %>
      <%= form_with model: @workout_routine_day_exercise, url: update_comment_workout_routine_workout_routine_day_workout_routine_day_exercise_path(
        @workout_routine_day_exercise.workout_routine_day.workout_routine,
        @workout_routine_day_exercise.workout_routine_day,
        @workout_routine_day_exercise
      ), method: :patch do |f| %>
        <div class="p-4 space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm text-slate-400 mb-1"><%= t(".sets_label") %></label>
              <%= f.text_field :sets,
                           placeholder: t(".sets_placeholder"),
                           class:
                             "w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
            </div>
            <div>
              <label class="block text-sm text-slate-400 mb-1"><%= t(".reps_label") %></label>
              <%= f.text_field :reps,
                           placeholder: t(".reps_placeholder"),
                           class:
                             "w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm text-slate-400 mb-1"><%= t(".min_rest_label") %></label>
              <%= f.number_field :min_rest,
                             placeholder: t(".rest_placeholder"),
                             min: 1,
                             class:
                               "w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
            </div>
            <div>
              <label class="block text-sm text-slate-400 mb-1"><%= t(".max_rest_label") %></label>
              <%= f.number_field :max_rest,
                             placeholder: t(".rest_placeholder"),
                             min: 1,
                             class:
                               "w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500" %>
            </div>
          </div>
          <%= f.text_area :comment,
                      rows: 3,
                      placeholder: t(".placeholder"),
                      class:
                        "w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 resize-none" %>
        </div>
        <div class="flex justify-end gap-2 p-4 border-t border-slate-700">
          <%= button t("shared.buttons.cancel"),
          style: "outlined",
          data: {
            action: "click->modal#close",
          } %>
          <%= button text: t("shared.buttons.save"), style: "primary", type: "submit" %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
