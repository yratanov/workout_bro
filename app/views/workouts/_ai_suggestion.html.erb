<div
  id="ai_suggestion_<%= index %>"
  class="
    flex items-start justify-between gap-3 bg-slate-700 rounded-lg px-3 py-2
  "
>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 mb-1">
      <span class="text-white text-sm font-medium"><%= suggestion["exercise"] %></span>
      <span class="text-xs px-1.5 py-0.5 rounded bg-slate-600 text-slate-300">
        <%= t("workouts.summary.suggestion_fields.#{suggestion["field"]}") %>
      </span>
    </div>
    <p class="text-slate-400 text-xs"><%= suggestion["reason"] %></p>
    <div class="mt-1 text-sm text-purple-300 font-mono"><%= suggestion["value"] %><%= "s" if suggestion["field"].to_s.end_with?("rest") %></div>
  </div>
  <div class="flex-shrink-0 pt-1">
    <% if suggestion["applied"] %>
      <span class="text-xs text-green-400 font-medium">
        <%= icon "check", size: "w-4 h-4", class: "inline" %>
        <%= t("workouts.summary.suggestion_applied") %>
      </span>
    <% else %>
      <%= button_to t("workouts.summary.suggestion_apply"),
      apply_ai_suggestion_workout_path(workout, suggestion_index: index),
      method: :patch,
      class:
        "text-xs px-2 py-1 rounded bg-purple-500/20 text-purple-300 hover:bg-purple-500/30 transition-colors" %>
    <% end %>
  </div>
</div>
