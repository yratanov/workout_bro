<div class="w-full">
  <%# Month navigation header %>
  <div class="flex items-center justify-between mb-4">
    <%= link_to prev_month_path,
        data: { turbo_frame: "calendar" },
        class: "p-2 hover:bg-slate-600 rounded" do %>
      <%= icon "chevron_left" %>
    <% end %>

    <h2 class="text-xl font-bold text-indigo-200"><%= month_title %></h2>

    <%= link_to next_month_path,
        data: { turbo_frame: "calendar" },
        class: "p-2 hover:bg-slate-600 rounded" do %>
      <%= icon "chevron_right" %>
    <% end %>
  </div>

  <%# Desktop: Grid view %>
  <div class="hidden md:block">
    <%# Day name headers %>
    <div class="grid grid-cols-7 gap-1 mb-1">
      <% day_names_full.each do |day_name| %>
        <div class="text-center text-sm font-medium text-slate-400 py-2">
          <%= day_name %>
        </div>
      <% end %>
    </div>

    <%# Calendar grid %>
    <div class="grid grid-cols-7 gap-1">
      <% weeks.each do |week| %>
        <% week.each do |date| %>
          <%= render(
            CalendarDayComponent.new(
              date: date,
              current_month: @current_date,
              workouts: @workouts_by_date[date] || [],
              mobile: false,
            ),
          ) %>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Mobile: Week-grouped list view %>
  <div
    class="md:hidden"
    data-controller="calendar-scroll"
    data-calendar-scroll-has-today-value="<%= current_month? %>"
  >
    <% mobile_weeks.each do |week_num, dates| %>
      <div class="mb-4">
        <div
          class="
            text-xs font-medium text-slate-400 uppercase tracking-wider mb-1 px-1
          "
        >
          <%= week_label(dates) %>
        </div>
        <div class="space-y-1">
          <% dates.each do |date| %>
            <%= render(
              CalendarDayComponent.new(
                date: date,
                current_month: @current_date,
                workouts: @workouts_by_date[date] || [],
                mobile: true,
              ),
            ) %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
